{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "clang",
      "args": [
        "-g",
        "-O0",
        "-o",
        "${workspaceFolder}/main",
        "${workspaceFolder}/main.c",
        "${workspaceFolder}/cs50.c"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "detail": "Компиляция main.c и cs50.c с отладочной информацией"
    }
  ]
}
